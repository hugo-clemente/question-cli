    "check": "vp check",
    "build": "vp pack",
    "prepublishOnly": "vp pack"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "discord.js": "14.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite-plus": "^0.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
