{
  "name": "question-cli",
  "version": "0.1.0",
  "bin": {
    "question": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test $(find test -name '*.test.ts' -type f | sort)",
    "start": "node --import tsx src/cli.ts",
    "lint": "vp lint",
